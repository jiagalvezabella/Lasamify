@{
    ViewData["Title"] = "Order Receipt";
    Layout = "_Layout";
}

<style>
    :root {
        --primary: #FFB703; 
        --primary-hover: #FF9E00;
        --black: #0B0F19; 
        --dark: #1C2434;
        --gray: #64748B;
        --white: #FFFFFF;
        --success: #10B981;
    }

    .receipt-container {
        max-width: 600px;
        margin: 2rem auto;
        padding: 2rem;
        background: var(--white);
        border: 1px solid rgba(0,0,0,0.1);
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .receipt-header {
        text-align: center;
        border-bottom: 2px solid var(--primary);
        padding-bottom: 1.5rem;
        margin-bottom: 2rem;
    }

    .receipt-title {
        font-size: 2rem;
        font-weight: 900;
        color: var(--black);
        margin: 0 0 0.5rem 0;
    }

    .receipt-subtitle {
        color: var(--gray);
        font-size: 0.9rem;
    }

    .receipt-section {
        margin-bottom: 2rem;
    }

    .receipt-section-title {
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--primary);
        margin-bottom: 1rem;
        border-bottom: 1px solid rgba(0,0,0,0.1);
        padding-bottom: 0.5rem;
    }

    .receipt-info {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }

    .info-item {
        font-size: 0.9rem;
    }

    .info-label {
        color: var(--gray);
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        margin-bottom: 0.25rem;
    }

    .info-value {
        color: var(--black);
        font-weight: 700;
        font-size: 1rem;
    }

    .receipt-details {
        background: rgba(255, 183, 3, 0.05);
        padding: 1.5rem;
        border-radius: 8px;
        margin-bottom: 1.5rem;
    }

    .detail-row {
        display: flex;
        justify-content: space-between;
        margin-bottom: 0.75rem;
        font-size: 0.95rem;
    }

    .detail-label {
        color: var(--gray);
        font-weight: 600;
    }

    .detail-value {
        color: var(--black);
        font-weight: 700;
    }

    .detail-total {
        border-top: 2px solid var(--primary);
        padding-top: 1rem;
        margin-top: 1rem;
    }

    .total-amount {
        font-size: 1.5rem;
        color: var(--primary-hover);
        font-weight: 900;
    }

    .status-badge {
        display: inline-block;
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 800;
        text-transform: uppercase;
        margin: 0.25rem;
    }

    .status-accepted {
        background: rgba(16, 185, 129, 0.15);
        color: #059669;
    }

    .status-pending {
        background: rgba(255, 183, 3, 0.15);
        color: var(--primary-hover);
    }

    .status-rejected {
        background: rgba(239, 68, 68, 0.15);
        color: #DC2626;
    }

    .receipt-footer {
        text-align: center;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(0,0,0,0.1);
        color: var(--gray);
        font-size: 0.85rem;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        margin-top: 2rem;
    }

    .btn {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        border: none;
        font-weight: 800;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-primary {
        background: var(--primary);
        color: var(--black);
    }

    .btn-primary:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
    }

    .btn-secondary {
        background: var(--dark);
        color: var(--white);
    }

    .btn-secondary:hover {
        background: var(--black);
        transform: translateY(-2px);
    }

    @@media print {
        .action-buttons {
            display: none;
        }
        .receipt-container {
            box-shadow: none;
            border: none;
        }
    }
</style>

<div class="receipt-container">
    <div class="receipt-header">
        <h1 class="receipt-title">RECEIPT</h1>
        <p class="receipt-subtitle">Order Receipt #@Model.TransactionId</p>
    </div>

    <div class="receipt-section">
        <h3 class="receipt-section-title">Transaction Details</h3>
        <div class="receipt-info">
            <div class="info-item">
                <div class="info-label">Receipt Number</div>
                <div class="info-value">#@Model.TransactionId</div>
            </div>
            <div class="info-item">
                <div class="info-label">Date</div>
                <div class="info-value">@Model.TransactionDate.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>

    <div class="receipt-section">
        <h3 class="receipt-section-title">Buyer Information</h3>
        <div class="receipt-info">
            <div class="info-item">
                <div class="info-label">Name</div>
                <div class="info-value">@Model.BuyerName</div>
            </div>
            <div class="info-item">
                <div class="info-label">Email</div>
                <div class="info-value">@Model.BuyerEmail</div>
            </div>
        </div>
    </div>

    <div class="receipt-section">
        <h3 class="receipt-section-title">Seller Information</h3>
        <div class="receipt-info">
            <div class="info-item">
                <div class="info-label">Name</div>
                <div class="info-value">@Model.SellerName</div>
            </div>
            <div class="info-item">
                <div class="info-label">Email</div>
                <div class="info-value">@Model.SellerEmail</div>
            </div>
        </div>
    </div>

    <div class="receipt-section">
        <h3 class="receipt-section-title">Product Details</h3>

        <div class="receipt-details">
            <div class="detail-row">
                <span class="detail-label">Product Name</span>
                <span class="detail-value">@Model.ProductName</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Unit Price</span>
                <span class="detail-value">₱@Model.ProductPrice.ToString("N2")</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Quantity</span>
                <span class="detail-value">@Model.Quantity x</span>
            </div>
            <div class="detail-row detail-total">
                <span class="detail-label">Total Amount</span>
                <span class="total-amount">₱@Model.TotalAmount.ToString("N2")</span>
            </div>
        </div>
    </div>

    <div class="receipt-section">
        <h3 class="receipt-section-title">Order Status</h3>
        <div style="margin-bottom: 1rem;">
            <strong style="color: var(--black);">Order Status:</strong>
            <span class="status-badge status-@Model.Status.ToLower()">@Model.Status</span>
        </div>
        <div>
            <strong style="color: var(--black);">Seller Response:</strong>
            <span class="status-badge status-@(Model.SellerStatus?.ToLower() ?? "pending")">@(Model.SellerStatus ?? "Pending")</span>
        </div>
        @if (Model.SellerResponseDate.HasValue)
        {
            <p style="color: var(--gray); font-size: 0.85rem; margin-top: 0.5rem;">
                <strong>Response Date:</strong> @Model.SellerResponseDate.Value.ToString("MMM dd, yyyy HH:mm:ss")
            </p>
        }
    </div>

    <div class="receipt-footer">
        <p>Thank you for your transaction!</p>
        <p>Lasamify Community Marketplace</p>
    </div>

    <div class="action-buttons">
        <button class="btn btn-secondary" onclick="window.print()">
            <i class="fa-solid fa-print"></i> Print
        </button>
        <a href="@Url.Action("Profile", "Account")" class="btn btn-primary">
            <i class="fa-solid fa-arrow-left"></i> Back to Profile
        </a>
    </div>
</div>
