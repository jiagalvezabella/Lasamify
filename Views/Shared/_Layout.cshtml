<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Lasamify</title>
    <link rel="icon" type="image/jpeg" href="~/favicon/favicon.jpg" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #FFB703; 
            --primary-hover: #FF9E00;
            --primary-light: #FFF4D6;
            --black: #0B0F19; 
            --dark: #1C2434;
            --gray: #64748B;
            --light-border: #E2E8F0;
            --bg-light: #F8FAFC;
            --white: #FFFFFF;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-light);
            color: var(--black);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        h1, h2, h3, .logo { font-family: 'Outfit', sans-serif; }

        /* --- NAVIGATION --- */
        nav {
            display: flex; justify-content: space-between; align-items: center;
            padding: 1.2rem 4rem; position: sticky; top: 0;
            background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--light-border); z-index: 100;
        }
        .logo { font-size: 1.75rem; font-weight: 900; color: var(--black); letter-spacing: -0.5px; text-decoration: none; display: flex; align-items: center; gap: 8px; }
        .logo-dot { width: 12px; height: 12px; background: var(--primary); border-radius: 50%; display: inline-block; }
        .nav-links { display: flex; gap: 2.5rem; align-items: center; }
        .nav-links a { color: var(--gray); text-decoration: none; font-size: 0.95rem; font-weight: 500; transition: color 0.2s; }
        .nav-links a:hover { color: var(--black); }
        .nav-cta { background: var(--black) !important; color: var(--white) !important; padding: 0.6rem 1.5rem; border-radius: 8px; font-weight: 600 !important; transition: transform 0.2s, background 0.2s !important; }
        .nav-cta:hover { background: var(--primary) !important; color: var(--black) !important; transform: translateY(-2px); }
        .nav-logout-btn { background: none; border: none; color: var(--gray); font-size: 0.95rem; font-weight: 500; cursor: pointer; transition: color 0.2s; padding: 0; font-family: inherit; }
        .nav-logout-btn:hover { color: var(--black); }
        .nav-logout-form { display: inline; margin: 0; padding: 0; }

        /* --- MAIN CONTENT --- */
        main {
            min-height: calc(100vh - 80px);
            padding: 3rem 4rem;
        }

        /* --- ALERTS --- */
        .alert-box {
            padding: 1rem 1.5rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            display: flex;
            gap: 1rem;
            align-items: flex-start;
            animation: slideDown 0.3s ease;
        }

        .alert-success {
            background: #D1FAE5;
            border: 1px solid #10B981;
            color: #047857;
        }

        .alert-error {
            background: #FEE2E2;
            border: 1px solid #EF4444;
            color: #991B1B;
        }

        .alert-close {
            background: none;
            border: none;
            color: inherit;
            cursor: pointer;
            font-size: 1.25rem;
            margin-left: auto;
            transition: opacity 0.2s;
        }

        .alert-close:hover { opacity: 0.7; }

        @@keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- FOOTER --- */
        footer {
            background: var(--black);
            border-top: 1px solid rgba(255,255,255,0.05);
            padding: 2rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: var(--gray);
            font-size: 0.85rem;
        }

        .footer-logo {
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Outfit', sans-serif;
            font-size: 1.25rem;
            font-weight: 800;
            color: var(--white);
            text-decoration: none;
        }

        @@media (max-width: 1024px) {
            nav { padding: 1rem 1.5rem; }
            main { padding: 2rem 1.5rem; }
            footer { padding: 1.5rem; flex-direction: column; gap: 1rem; text-align: center; }
        }
    </style>
</head>
<body>

<nav>
    <a class="logo" asp-controller="Home" asp-action="Index">
        <span class="logo-dot"></span> Lasamify
    </a>
    <div class="nav-links">
        <a asp-controller="Home" asp-action="Index">Marketplace</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Account" asp-action="Profile" class="nav-cta">
                <i class="fa-solid fa-circle-user me-2"></i> Dashboard
            </a>
            <form method="post" asp-controller="Account" asp-action="Logout" class="nav-logout-form">
                @Html.AntiForgeryToken()
                <button type="submit" class="nav-logout-btn">Logout</button>
            </form>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Log In</a>
            <a asp-controller="Account" asp-action="Register" class="nav-cta">Sign Up Free</a>
        }
    </div>
</nav>

<main>
    @if (TempData["Success"] != null)
    {
        <div class="alert-box alert-success">
            <i class="fa-solid fa-check-circle"></i>
            <span>@TempData["Success"]</span>
            <button class="alert-close" onclick="this.parentElement.style.display='none';">&times;</button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert-box alert-error">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>@TempData["Error"]</span>
            <button class="alert-close" onclick="this.parentElement.style.display='none';">&times;</button>
        </div>
    }

    @RenderBody()
</main>

<footer>
    <a class="footer-logo" asp-controller="Home" asp-action="Index">
        <span class="logo-dot"></span> Lasamify
    </a>
    <span class="footer-copy">&copy; 2026 Lasamify &mdash; Your Local Marketplace</span>
</footer>

</body>
</html>
