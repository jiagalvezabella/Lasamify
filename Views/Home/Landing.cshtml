@{
    ViewData["Title"] = "Lasamify - Your Local Marketplace";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lasamify — Your Local Marketplace</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --gold: #e8b84b;
            --gold-light: #f5d68a;
            --cream: #f0ece0;
            --dark: #0d0d0d;
            --dark2: #161616;
            --dark3: #1e1e1e;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--dark);
            color: var(--cream);
            overflow-x: hidden;
        }

        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.2rem 4rem;
            border-bottom: 0.5px solid rgba(232,184,75,0.2);
            position: sticky;
            top: 0;
            background: rgba(13,13,13,0.95);
            backdrop-filter: blur(8px);
            z-index: 100;
        }
        .logo {
            font-family: 'Playfair Display', serif;
            font-size: 1.7rem;
            font-weight: 900;
            color: var(--gold);
            letter-spacing: 1px;
            text-decoration: none;
        }
        .nav-links { display: flex; gap: 2rem; align-items: center; }
        .nav-links a {
            color: rgba(240,236,224,0.65);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 400;
            letter-spacing: 0.5px;
            transition: color 0.2s;
        }
        .nav-links a:hover { color: var(--gold); }
        .nav-cta {
            background: var(--gold) !important;
            color: #0d0d0d !important;
            padding: 0.5rem 1.25rem;
            border-radius: 4px;
            font-weight: 500 !important;
        }
        .nav-cta:hover { background: var(--gold-light) !important; }

        .hero {
            min-height: 92vh;
            display: flex;
            align-items: center;
            padding: 4rem;
            position: relative;
            overflow: hidden;
        }
        .hero-bg {
            position: absolute; inset: 0;
            background: radial-gradient(ellipse 80% 60% at 60% 50%, rgba(232,184,75,0.06) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero-grid {
            position: absolute; inset: 0;
            background-image: linear-gradient(rgba(232,184,75,0.04) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(232,184,75,0.04) 1px, transparent 1px);
            background-size: 60px 60px;
            pointer-events: none;
        }
        .hero-content { max-width: 620px; position: relative; z-index: 2; }
        .hero-tag {
            display: inline-block;
            font-size: 0.75rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--gold);
            border: 0.5px solid rgba(232,184,75,0.4);
            padding: 0.35rem 0.85rem;
            border-radius: 2px;
            margin-bottom: 1.5rem;
        }
        h1 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(3rem, 6vw, 5.5rem);
            font-weight: 900;
            line-height: 1.05;
            color: var(--cream);
            margin-bottom: 1.5rem;
        }
        h1 span { color: var(--gold); }
        .hero-desc {
            font-size: 1.1rem;
            color: rgba(240,236,224,0.65);
            line-height: 1.8;
            max-width: 480px;
            margin-bottom: 2.5rem;
            font-weight: 300;
        }
        .hero-actions { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
        .btn-primary {
            background: var(--gold);
            color: #0d0d0d;
            padding: 0.85rem 2rem;
            border-radius: 4px;
            font-weight: 500;
            font-size: 0.95rem;
            text-decoration: none;
            transition: background 0.2s;
            display: inline-block;
        }
        .btn-primary:hover { background: var(--gold-light); color: #0d0d0d; }
        .btn-ghost {
            color: var(--cream);
            padding: 0.85rem 2rem;
            border-radius: 4px;
            font-weight: 400;
            font-size: 0.95rem;
            text-decoration: none;
            border: 0.5px solid rgba(240,236,224,0.25);
            transition: all 0.2s;
            display: inline-block;
        }
        .btn-ghost:hover { border-color: var(--gold); color: var(--gold); }
        .hero-stats {
            display: flex;
            gap: 3rem;
            margin-top: 4rem;
            padding-top: 2rem;
            border-top: 0.5px solid rgba(240,236,224,0.1);
        }
        .stat-num {
            font-family: 'Playfair Display', serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--gold);
        }
        .stat-label {
            font-size: 0.8rem;
            color: rgba(240,236,224,0.5);
            margin-top: 0.2rem;
            letter-spacing: 0.5px;
        }

        .hero-visual {
            position: absolute;
            right: 4rem;
            top: 50%;
            transform: translateY(-50%);
            width: 400px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            z-index: 2;
            animation: float 6s ease-in-out infinite;
        }
        .product-card-demo {
            background: var(--dark3);
            border: 0.5px solid rgba(232,184,75,0.15);
            border-radius: 8px;
            overflow: hidden;
            transition: transform 0.3s, border-color 0.3s;
        }
        .product-card-demo:hover { transform: translateY(-4px); border-color: rgba(232,184,75,0.4); }
        .card-img { width: 100%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; background: #1a1a1a; }
        .card-body { padding: 0.75rem; }
        .card-name { font-size: 0.8rem; font-weight: 500; color: var(--cream); margin-bottom: 0.25rem; }
        .card-price { font-size: 0.9rem; font-weight: 500; color: var(--gold); }
        .card-seller { font-size: 0.7rem; color: rgba(240,236,224,0.4); margin-top: 0.2rem; }
        .card-featured { grid-column: span 2; display: flex; }
        .card-featured .card-img { width: 110px; flex-shrink: 0; aspect-ratio: auto; height: 100%; }
        .card-featured .card-body { padding: 1rem; }
        .card-featured .card-name { font-size: 0.9rem; }
        .card-featured .card-price { font-size: 1.1rem; }

        .features-section {
            background: var(--dark2);
            padding: 6rem 4rem;
            border-top: 0.5px solid rgba(232,184,75,0.1);
            border-bottom: 0.5px solid rgba(232,184,75,0.1);
        }
        .features-inner { max-width: 1100px; margin: 0 auto; }
        .section-label { font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; color: var(--gold); margin-bottom: 1rem; }
        .section-title {
            font-family: 'Playfair Display', serif;
            font-size: clamp(1.8rem, 3vw, 2.8rem);
            font-weight: 700;
            color: var(--cream);
            margin-bottom: 1rem;
            line-height: 1.2;
        }
        .section-sub { color: rgba(240,236,224,0.55); font-size: 1rem; max-width: 500px; line-height: 1.8; font-weight: 300; }
        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2px;
            margin-top: 3rem;
            border: 0.5px solid rgba(232,184,75,0.1);
            border-radius: 8px;
            overflow: hidden;
        }
        .feature-item {
            background: var(--dark3);
            padding: 2rem;
            border-right: 0.5px solid rgba(232,184,75,0.1);
        }
        .feature-item:last-child { border-right: none; }
        .feature-icon {
            width: 42px; height: 42px;
            background: rgba(232,184,75,0.1);
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            margin-bottom: 1.25rem;
            font-size: 1.2rem;
        }
        .feature-title { font-size: 1rem; font-weight: 500; color: var(--cream); margin-bottom: 0.5rem; }
        .feature-desc { font-size: 0.85rem; color: rgba(240,236,224,0.5); line-height: 1.7; font-weight: 300; }

        .how-section { padding: 6rem 4rem; background: var(--dark); }
        .how-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
        .steps { margin-top: 2.5rem; }
        .step { display: flex; gap: 1.5rem; padding: 1.5rem 0; border-bottom: 0.5px solid rgba(240,236,224,0.08); }
        .step:last-child { border-bottom: none; }
        .step-num { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 700; color: rgba(232,184,75,0.3); flex-shrink: 0; width: 2rem; line-height: 1; }
        .step-title { font-size: 0.95rem; font-weight: 500; color: var(--cream); margin-bottom: 0.35rem; }
        .step-desc { font-size: 0.83rem; color: rgba(240,236,224,0.5); line-height: 1.7; font-weight: 300; }
        .mockup-phone {
            background: var(--dark3);
            border: 0.5px solid rgba(232,184,75,0.2);
            border-radius: 16px;
            padding: 1.5rem;
            width: 280px;
            margin: 0 auto;
        }
        .mockup-bar { display: flex; gap: 8px; align-items: center; margin-bottom: 1.5rem; }
        .mockup-dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(240,236,224,0.15); }
        .mockup-url { flex: 1; background: rgba(240,236,224,0.06); border-radius: 4px; height: 24px; display: flex; align-items: center; padding: 0 0.75rem; font-size: 0.65rem; color: rgba(240,236,224,0.3); }
        .mockup-search { background: rgba(240,236,224,0.06); border-radius: 6px; padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
        .mockup-search span { font-size: 0.7rem; color: rgba(240,236,224,0.3); }
        .mockup-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
        .mockup-product { background: rgba(240,236,224,0.04); border: 0.5px solid rgba(232,184,75,0.1); border-radius: 6px; padding: 0.75rem; text-align: center; }
        .mockup-product-img { font-size: 1.5rem; margin-bottom: 0.5rem; }
        .mockup-product-name { font-size: 0.65rem; color: rgba(240,236,224,0.6); margin-bottom: 0.25rem; }
        .mockup-product-price { font-size: 0.75rem; font-weight: 500; color: var(--gold); }

        .cta-section {
            background: var(--dark2);
            border-top: 0.5px solid rgba(232,184,75,0.15);
            padding: 6rem 4rem;
            text-align: center;
        }
        .cta-inner { max-width: 600px; margin: 0 auto; }
        .cta-inner h2 {
            font-family: 'Playfair Display', serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            font-weight: 900;
            color: var(--cream);
            margin-bottom: 1rem;
            line-height: 1.1;
        }
        .cta-inner h2 span { color: var(--gold); }
        .cta-inner p { color: rgba(240,236,224,0.55); font-size: 1rem; margin-bottom: 2rem; font-weight: 300; line-height: 1.7; }
        .cta-buttons { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

        footer {
            background: var(--dark);
            border-top: 0.5px solid rgba(240,236,224,0.08);
            padding: 2rem 4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .footer-logo { font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 700; color: var(--gold); text-decoration: none; }
        .footer-copy { font-size: 0.75rem; color: rgba(240,236,224,0.3); }

        @@keyframes float {
            0%, 100% { transform: translateY(-50%) translateX(0); }
            50% { transform: translateY(-52%) translateX(-6px); }
        }
        @@keyframes fadeUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .hero-content > * { animation: fadeUp 0.6s ease both; }
        .hero-tag { animation-delay: 0.1s; }
        .hero h1 { animation-delay: 0.2s; }
        .hero-desc { animation-delay: 0.3s; }
        .hero-actions { animation-delay: 0.4s; }
        .hero-stats { animation-delay: 0.5s; }

        @@media (max-width: 1024px) {
            .hero-visual { display: none; }
            nav { padding: 1rem 1.5rem; }
            .hero { padding: 3rem 1.5rem; }
            .features-section, .how-section, .cta-section { padding: 4rem 1.5rem; }
            .how-inner { grid-template-columns: 1fr; gap: 3rem; }
            footer { padding: 1.5rem; flex-direction: column; gap: 1rem; text-align: center; }
            .features-grid { grid-template-columns: 1fr; }
            .feature-item { border-right: none; border-bottom: 0.5px solid rgba(232,184,75,0.1); }
        }
    </style>
</head>
<body>


<nav>
    <a class="logo" asp-controller="Home" asp-action="Index">Lasamify</a>
    <div class="nav-links">
        <a asp-controller="Home" asp-action="Index">Browse</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Account" asp-action="Profile">
                <i class="fa-solid fa-circle-user"></i> @User.Identity.Name
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Login">Login</a>
            <a asp-controller="Account" asp-action="Register" class="nav-cta">Sign Up Free</a>
        }
    </div>
</nav>


<section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-grid"></div>

    <div class="hero-content">
        <span class="hero-tag">Local Marketplace</span>
        <h1>Buy &amp; Sell<br/>with <span>Lasamify</span></h1>
        <p class="hero-desc">
            Your trusted community marketplace. Post products, find great deals,
            and connect with buyers and sellers near you.
        </p>
        <div class="hero-actions">
            <a asp-controller="Account" asp-action="Register" class="btn-primary">
                <i class="fa-solid fa-store me-1"></i> Start Selling
            </a>
            <a asp-controller="Home" asp-action="Index" class="btn-ghost">
                Browse Products
            </a>
        </div>
        <div class="hero-stats">
            <div>
                <div class="stat-num">Secure</div>
                <div class="stat-label">Transactions</div>
            </div>
            <div>
                <div class="stat-num">Fast</div>
                <div class="stat-label">& Easy Listing</div>
            </div>
            <div>
                <div class="stat-num">Free</div>
                <div class="stat-label">To Join</div>
            </div>
        </div>
    </div>

    
    <div class="hero-visual">
        <div class="product-card-demo">
            <div class="card-img"></div>
            <div class="card-body">
                <div class="card-name">N/A</div>
                <div class="card-price">N/A</div>
                <div class="card-seller">by Lasam</div>
            </div>
        </div>
        <div class="product-card-demo">
            <div class="card-img"></div>
            <div class="card-body">
                <div class="card-name">N/A</div>
                <div class="card-price">N/A</div>
                <div class="card-seller">by Lasam</div>
            </div>
        </div>
        <div class="product-card-demo card-featured">
            <div class="card-img"></div>
            <div class="card-body">
                <div class="card-name">N/A</div>
                <div class="card-price">N/A</div>
                <div class="card-seller">by Lasam · 3 in stock</div>
            </div>
        </div>
    </div>
</section>


<section class="features-section">
    <div class="features-inner">
        <div class="section-label">Why Lasamify</div>
        <div class="section-title">Everything you need<br/>to trade locally</div>
        <div class="features-grid">
            <div class="feature-item">
                <div class="feature-icon"><i class="fa-solid fa-cart-shopping" style="color:var(--gold)"></i></div>
                <div class="feature-title">Easy Transactions</div>
                <div class="feature-desc">Place orders in seconds. Track every purchase and sale from your personal dashboard with full history.</div>
            </div>
            <div class="feature-item">
                <div class="feature-icon"><i class="fa-solid fa-magnifying-glass" style="color:var(--gold)"></i></div>
                <div class="feature-title">Smart Search</div>
                <div class="feature-desc">Find exactly what you're looking for with powerful search and category filters across all listings.</div>
            </div>
            <div class="feature-item">
                <div class="feature-icon"><i class="fa-solid fa-user" style="color:var(--gold)"></i></div>
                <div class="feature-title">Seller Profiles</div>
                <div class="feature-desc">Build your reputation. Upload a profile photo and manage all your listings in one convenient place.</div>
            </div>
        </div>
    </div>
</section>


<section class="how-section">
    <div class="how-inner">
        <div>
            <div class="section-label">How it works</div>
            <div class="section-title">Up and running<br/>in minutes</div>
            <div class="steps">
                <div class="step">
                    <div class="step-num">1</div>
                    <div>
                        <div class="step-title">Create your account</div>
                        <div class="step-desc">Sign up for free as a buyer or seller. Upload your profile photo to get started.</div>
                    </div>
                </div>
                <div class="step">
                    <div class="step-num">2</div>
                    <div>
                        <div class="step-title">List or browse products</div>
                        <div class="step-desc">Post your items with photos and prices, or search thousands of local listings by category.</div>
                    </div>
                </div>
                <div class="step">
                    <div class="step-num">3</div>
                    <div>
                        <div class="step-title">Buy &amp; sell with ease</div>
                        <div class="step-desc">Complete transactions securely. Track your full order history from your profile page.</div>
                    </div>
                </div>
            </div>
        </div>

        
        <div class="mockup-phone">
            <div class="mockup-bar">
                <div class="mockup-dot"></div>
                <div class="mockup-dot"></div>
                <div class="mockup-dot"></div>
                <div class="mockup-url">lasamify / marketplace</div>
            </div>
            <div class="mockup-search">
                <span><i class="fa-solid fa-magnifying-glass"></i></span>
                <span>Search products...</span>
            </div>
            <div class="mockup-grid">
                <div class="mockup-product">
                    <div class="mockup-product-img">👜</div>
                    <div class="mockup-product-name">Bag</div>
                    <div class="mockup-product-price">₱1,200</div>
                </div>
                <div class="mockup-product">
                    <div class="mockup-product-img">📚</div>
                    <div class="mockup-product-name">Books</div>
                    <div class="mockup-product-price">₱350</div>
                </div>
                <div class="mockup-product">
                    <div class="mockup-product-img">🎮</div>
                    <div class="mockup-product-name">Console</div>
                    <div class="mockup-product-price">₱12,000</div>
                </div>
                <div class="mockup-product">
                    <div class="mockup-product-img">🧥</div>
                    <div class="mockup-product-name">Jacket</div>
                    <div class="mockup-product-price">₱850</div>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="cta-section">
    <div class="cta-inner">
        <h2>Ready to join<br/><span>Lasamify?</span></h2>
        <p>Sign up today and start buying or selling in your community. It's completely free.</p>
        <div class="cta-buttons">
            <a asp-controller="Account" asp-action="Register" class="btn-primary">Create Free Account</a>
            <a asp-controller="Home" asp-action="Index" class="btn-ghost">Browse Listings</a>
        </div>
    </div>
</section>


<footer>
    <a class="footer-logo" asp-controller="Home" asp-action="Landing">Lasamify</a>
    <div class="footer-copy">© 2026 Lasamify. Your local marketplace.</div>
</footer>

</body>
</html>
