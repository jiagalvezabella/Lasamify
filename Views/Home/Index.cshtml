@model Lasamify.Models.ProductSearchViewModel
@{
    ViewData["Title"] = "Marketplace";
    Layout = "_Layout";
}

<style>
    :root {
        --primary: #FFB703;
        --primary-hover: #FF9E00;
        --black: #0B0F19;
        --gray: #64748B;
        --white: #FFFFFF;
        --glass-bg: rgba(255, 255, 255, 0.80);
        --glass-border: rgba(255, 255, 255, 0.5);
        --glass-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
    }

    body {
        color: var(--black);
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        margin: 0;
        padding: 0;
        position: relative;
    }

    .gif-bg-light {
        position: fixed;
        top: 0; left: 0; width: 50vw; height: 100vh;
        background: url('/images/light-bg3.gif') top left;
        background-size: 100% auto;
        background-repeat: repeat-y;
        z-index: -1;
    }

    .gif-bg-light::after {
        content: '';
        position: fixed;
        top: 0; left: 50vw; width: 50vw; height: 100vh;
        background: url('/images/light-bg3.gif') top left;
        background-size: 100% auto;
        background-repeat: repeat-y;
        transform: scaleX(-1);
        z-index: -1;
    }

    .container-marketplace {
        max-width: 1200px;
        margin: 0 auto;
        width: 100%;
        position: relative;
        z-index: 1;
        padding-top: 2rem;
        padding-bottom: 4rem;
    }

    .marketplace-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        gap: 2rem;
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        padding: 1.5rem 2rem;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        box-shadow: var(--glass-shadow);
    }

    .marketplace-header h1 {
        font-family: 'Outfit', sans-serif;
        font-size: 2.25rem;
        font-weight: 900;
        color: var(--black);
        margin: 0;
    }

    .btn-list-product {
        background: var(--primary);
        color: var(--black);
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.2s;
        box-shadow: 0 4px 14px rgba(255, 183, 3, 0.4);
        white-space: nowrap;
        border: none;
        display: inline-flex;
        align-items: center;
    }

    .btn-list-product:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(255, 183, 3, 0.5);
        color: var(--black);
    }

    .search-bar {
        display: flex;
        gap: 1rem;
        margin-bottom: 2.5rem;
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 1.5rem 2rem;
        box-shadow: var(--glass-shadow);
    }

    .search-input-wrapper {
        flex: 1;
        position: relative;
    }

    .search-input {
        width: 100%;
        padding: 1rem 1.5rem;
        border: 1px solid rgba(0,0,0,0.1);
        border-radius: 8px 0 0 8px;
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: rgba(255, 255, 255, 0.8);
        color: var(--black);
    }

    .search-input:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(255, 183, 3, 0.2);
        background: var(--white);
    }

    .search-input::placeholder {
        color: var(--gray);
    }

    .search-bar form {
        display: flex;
        gap: 0;
        width: 100%;
    }

    .btn-search {
        background: var(--primary);
        color: var(--black);
        border: none;
        padding: 0.5rem 2rem;
        border-radius: 0 8px 8px 0;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.2s;
        box-shadow: 0 4px 14px rgba(255, 183, 3, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
    }

    .btn-search:hover {
        background: var(--primary-hover);
    }

    .category-filters {
        display: flex;
        gap: 1rem;
        margin-bottom: 2.5rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
    }

    .category-pill {
        background: var(--glass-bg);
        color: var(--black);
        border: 1px solid var(--glass-border);
        padding: 0.6rem 1.5rem;
        border-radius: 50px;
        font-size: 0.95rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
        cursor: pointer;
        backdrop-filter: blur(8px);
        box-shadow: var(--glass-shadow);
    }

    .category-pill:hover,
    .category-pill.active {
        background: var(--primary);
        color: var(--black);
        border-color: var(--primary);
        box-shadow: 0 4px 15px rgba(255, 183, 3, 0.4);
    }

    .results-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        padding: 1.5rem 2rem;
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        box-shadow: var(--glass-shadow);
    }

    .results-title {
        font-family: 'Outfit', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--black);
        margin: 0;
    }

    .results-count {
        color: var(--gray);
        font-size: 0.95rem;
        font-weight: 700;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2.5rem;
        margin-bottom: 4rem;
        padding: 0;
        perspective: 1200px;
    }

    .product-card {
        background: transparent;
        border-radius: 12px;
        border: none;
        overflow: visible;
        transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        height: 100%;
        position: relative;
        z-index: 1;
        transform-style: preserve-3d;
        cursor: pointer;
        min-height: 420px;
    }

    .product-card:hover {
        transform: rotateY(180deg);
        z-index: 10;
    }

    .product-card-front {
        backface-visibility: hidden;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow: hidden;
        border-radius: 12px;
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid var(--glass-border);
        box-shadow: var(--glass-shadow);
    }

    .product-card-back {
        backface-visibility: hidden;
        transform: rotateY(180deg);
        display: flex;
        flex-direction: column;
        height: 100%;
        padding: 2rem;
        justify-content: center;
        text-align: center;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border: 2px solid var(--primary);
        box-shadow: 0 20px 40px rgba(255, 183, 3, 0.2);
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        border-radius: 12px;
    }

    .product-card-back h3 {
        font-family: 'Outfit', sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--black);
        margin: 0 0 1rem 0;
    }

    .product-card-back p {
        font-size: 0.9rem;
        color: var(--gray);
        line-height: 1.6;
        margin: 0 0 1.5rem 0;
        flex-grow: 1;
    }

    .product-card-back-actions {
        display: flex;
        gap: 1rem;
        flex-direction: column;
    }

    .product-card-back-btn {
        background: var(--primary);
        color: var(--black);
        border: none;
        padding: 0.75rem 1rem;
        border-radius: 6px;
        font-weight: 800;
        text-decoration: none;
        transition: all 0.2s;
        font-size: 0.9rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .product-card-back-btn:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
    }

    .product-card-back-btn.secondary {
        background: transparent;
        color: var(--black);
        border: 2px solid var(--black);
    }

    .product-card-back-btn.secondary:hover {
        background: var(--black);
        color: var(--white);
    }

    .product-image-wrapper {
        width: 100%;
        height: 200px;
        overflow: hidden;
        background: rgba(0, 0, 0, 0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        position: relative;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

    .product-image-wrapper a {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

    .product-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease-in-out;
        display: block;
    }

    .product-card-front:hover .product-img {
        transform: scale(1.08);
    }

    .product-img-placeholder {
        color: var(--gray);
        font-size: 3.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        height: 100%;
        opacity: 0.5;
    }

    .product-info {
        padding: 1.5rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .product-category {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        color: var(--primary-hover);
        margin: 0;
        letter-spacing: 0.7px;
    }

    .product-name {
        font-family: 'Outfit', sans-serif;
        font-size: 1.15rem;
        font-weight: 800;
        color: var(--black);
        margin: 0;
        text-decoration: none;
        display: block;
        transition: color 0.2s;
        line-height: 1.3;
    }

    .product-card-front:hover .product-name {
        color: var(--primary-hover);
    }

    .product-desc {
        font-size: 0.85rem;
        color: var(--gray);
        line-height: 1.6;
        margin: 0;
        flex-grow: 1;
    }

    .product-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 1rem;
        padding-top: 1rem;
        margin-top: auto;
        border-top: 1px solid rgba(0,0,0,0.05);
    }

    .product-price {
        font-family: 'Outfit', sans-serif;
        font-size: 1.4rem;
        font-weight: 900;
        color: var(--black);
        line-height: 1;
    }

    .product-meta {
        font-size: 0.8rem;
        color: var(--gray);
        margin-top: 0.35rem;
        font-weight: 700;
    }

    .view-product-btn {
        background: transparent;
        border: 1px solid var(--black);
        color: var(--black);
        padding: 0.55rem 1.1rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        text-align: center;
        white-space: nowrap;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .view-product-btn:hover {
        background: var(--black);
        color: var(--white);
        transform: translateX(2px);
    }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        box-shadow: var(--glass-shadow);
        margin-bottom: 4rem;
    }

    .empty-state i {
        font-size: 4rem;
        color: var(--gray);
        margin-bottom: 1.5rem;
        opacity: 0.5;
    }

    .empty-state h2 {
        font-family: 'Outfit', sans-serif;
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--black);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: var(--gray);
        margin-bottom: 2rem;
        font-size: 1.05rem;
    }

    .empty-state a {
        background: var(--primary);
        color: var(--black);
        padding: 0.85rem 1.75rem;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 800;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        box-shadow: 0 4px 15px rgba(255, 183, 3, 0.3);
    }

    .empty-state a:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
    }

    @@media (max-width: 768px) {
        .container-marketplace { padding: 2rem 1.5rem; }
        .marketplace-header { flex-direction: column; align-items: stretch; gap: 1.5rem;}
        .marketplace-header h1 { font-size: 2rem; text-align: center;}
        .btn-list-product { text-align: center; justify-content: center; display: flex;}
        .search-bar { flex-direction: column; padding: 1.5rem; }
        .search-input { border-radius: 8px 8px 0 0; }
        .btn-search { border-radius: 0 0 8px 8px; padding: 1rem; }
        .products-grid { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; }
        .results-info { flex-direction: column; gap: 1rem; text-align: center; }
        .gif-bg-light { width: 100vw; }
        .gif-bg-light::after { display: none; }
    }

    @@media (max-width: 480px) {
        .products-grid { grid-template-columns: 1fr; gap: 1.5rem; }
        .product-image-wrapper { height: 220px; }
    }
</style>

<div class="gif-bg-light"></div>

<div class="container-marketplace">
    <div class="marketplace-header">
        <div>
            <h1>
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <span>Search Results for "<span style="color:var(--primary-hover)">@Model.SearchQuery</span>"</span>
                }
                else if (!string.IsNullOrEmpty(Model.Category))
                {
                    <span><span style="color:var(--primary-hover)">@Model.Category</span> Products</span>
                }
                else
                {
                    <span>Browse Our <span style="color:var(--primary-hover)">Marketplace</span></span>
                }
            </h1>
        </div>
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Seller"))
        {
            <a asp-controller="Products" asp-action="Create" class="btn-list-product">
                <i class="fa-solid fa-plus me-2"></i>List a Product
            </a>
        }
    </div>

    <div class="search-bar">
        <div class="search-input-wrapper">
            <form method="get" asp-controller="Home" asp-action="Index">
                <input class="search-input" type="search" name="search"
                       placeholder="Search products, categories, electronics..." value="@Model.SearchQuery" />
                <button class="btn-search" type="submit">
                    <i class="fa-solid fa-magnifying-glass me-2"></i> Search
                </button>
            </form>
        </div>
    </div>

    <div class="category-filters">
        <a href="@Url.Action("Index")"
           class="category-pill @(string.IsNullOrEmpty(Model.Category) ? "active" : "")">All Categories</a>
        @foreach (var cat in new[] { "Electronics", "Clothing", "Food", "Books", "Services", "General" })
        {
            <a href="@Url.Action("Index", new { category = cat, search = Model.SearchQuery })"
               class="category-pill @(Model.Category == cat ? "active" : "")">@cat</a>
        }
    </div>

    <div class="results-info">
        <h2 class="results-title">
            @if (!Model.Products.Any())
            {
                <span>No Products Found</span>
            }
            else if (Model.Products.Count == 1)
            {
                <span>1 Product</span>
            }
            else
            {
                <span>@Model.Products.Count Products</span>
            }
        </h2>
        @if (Model.Products.Any())
        {
            <span class="results-count">Showing all available listings</span>
        }
    </div>

    @if (!Model.Products.Any())
    {
        <div class="empty-state">
            <i class="fa-solid fa-inbox"></i>
            <h2>No Products Found</h2>
            <p>
                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                {
                    <span>Try adjusting your search terms or browse all categories</span>
                }
                else
                {
                    <span>No products are currently available in this category</span>
                }
            </p>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Products" asp-action="Create">
                    <i class="fa-solid fa-plus me-2"></i>Be the First to List
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Register">
                    <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Sign Up to Sell
                </a>
            }
        </div>
    }
    else
    {
        <div class="products-grid">
            @foreach (var product in Model.Products)
            {
                <div class="product-card">
                    <div class="product-card-front">
                        <div class="product-image-wrapper">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" style="display: contents;">
                                @if (!string.IsNullOrEmpty(product.ImagePath))
                                {
                                    <img src="@product.ImagePath" class="product-img" alt="@product.Name" />
                                }
                                else
                                {
                                    <div class="product-img-placeholder">
                                        <i class="fa-solid fa-image"></i>
                                    </div>
                                }
                            </a>
                        </div>
                        <div class="product-info">
                            <div class="product-category">@product.Category</div>
                            <a asp-controller="Products" asp-action="Details"
                               asp-route-id="@product.Id" class="product-name">@product.Name</a>
                            <p class="product-desc">
                                @(string.IsNullOrEmpty(product.Description) ? "No description provided." : 
                                    (product.Description.Length > 75
                                        ? product.Description[..75] + "..."
                                        : product.Description))
                            </p>
                            <div class="product-footer">
                                <div>
                                    <div class="product-price">₱@product.Price.ToString("N2")</div>
                                    <div class="product-meta">@product.Stock in stock</div>
                                </div>
                                <a asp-controller="Products" asp-action="Details"
                                   asp-route-id="@product.Id" class="view-product-btn">
                                    View <i class="fa-solid fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <div class="product-card-back">
                        <h3>Quick Look</h3>
                        <p>
                            @(string.IsNullOrEmpty(product.Description) ? "High-quality product in stock and ready to ship!" : product.Description)
                        </p>
                        <div class="product-card-back-actions">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="product-card-back-btn">
                                <i class="fa-solid fa-arrow-right"></i> View Details
                            </a>
                            <button type="button" class="product-card-back-btn secondary" onclick="addToCart(@product.Id)">
                                <i class="fa-solid fa-cart-plus"></i> Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
    function addToCart(productId) {
        alert(`Product ${productId} added to cart!`);
    }
</script>