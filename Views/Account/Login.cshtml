@model Lasamify.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lasamify — Login</title>
    <link rel="icon" type="image/jpeg" href="~/favicon/favicon.jpg" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #FFB703;
            --primary-hover: #FF9E00;
            --black: #0B0F19;
            --gray: #64748B;
            --white: #FFFFFF;
            --glass-bg: rgba(255, 255, 255, 0.80);
            --glass-border: rgba(255, 255, 255, 0.5);
            --glass-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

        body {
            color: var(--black);
            font-family: 'DM Sans', sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }

        .bg-light-gif-container {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: -1;
            display: flex;
        }

        .bg-light-gif-left {
            width: 50%; height: 100%;
            background: url('/images/light-bg3.gif') top left;
            background-size: 100% auto;
            background-repeat: repeat-y;
        }

        .bg-light-gif-right {
            width: 50%; height: 100%;
            background: url('/images/light-bg3.gif') top left;
            background-size: 100% auto;
            background-repeat: repeat-y;
            transform: scaleX(-1);
        }

        .auth-container {
            width: 100%;
            max-width: 420px;
            padding: 2rem;
            position: relative;
            z-index: 1;
        }

        .auth-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
            padding: 3rem;
            box-shadow: var(--glass-shadow);
        }

        .auth-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .auth-header h1 {
            font-family: 'Outfit', sans-serif;
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--black);
            margin: 0 0 0.5rem 0;
        }

        .auth-header p {
            color: var(--gray);
            font-size: 0.95rem;
            margin: 0;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            font-weight: 600;
            color: var(--black);
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
        }

        .form-input {
            width: 100%;
            padding: 1rem 1.25rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            font-size: 1rem;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.2s;
            background: rgba(255, 255, 255, 0.8);
            color: var(--black);
            box-sizing: border-box;
        }

        .form-input:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(255, 183, 3, 0.2);
            background: var(--white);
        }

        .form-input::placeholder {
            color: var(--gray);
            opacity: 0.7;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
        }

        .checkbox-group input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: var(--primary);
        }

        .checkbox-group label {
            cursor: pointer;
            color: var(--black);
            font-size: 0.9rem;
            margin: 0;
            font-weight: 500;
        }

        .btn-primary {
            width: 100%;
            padding: 1rem;
            background: var(--primary);
            color: var(--black);
            border: none;
            border-radius: 8px;
            font-weight: 800;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 4px 14px rgba(255, 183, 3, 0.3);
        }

        .btn-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 183, 3, 0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0;
            color: var(--gray);
            font-size: 0.85rem;
            font-weight: 600;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(0, 0, 0, 0.1);
        }

        .auth-footer {
            text-align: center;
            color: var(--gray);
            font-size: 0.9rem;
            font-weight: 500;
        }

        .auth-link {
            color: var(--primary);
            text-decoration: none;
            font-weight: 800;
            transition: color 0.2s;
            margin-left: 0.25rem;
        }

        .auth-link:hover {
            color: var(--primary-hover);
            text-decoration: underline;
        }

        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: #DC2626;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .alert-error ul {
            margin: 0;
            padding-left: 1.25rem;
        }

        .back-nav {
            position: absolute;
            top: -3rem;
            left: 0;
            color: var(--black);
            text-decoration: none;
            font-weight: 700;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: color 0.2s;
        }

        .back-nav:hover {
            color: var(--primary);
        }

        @@media (max-width: 640px) {
            .auth-container { padding: 1rem; margin-top: 2rem; }
            .auth-card { padding: 2rem; }
            .auth-header h1 { font-size: 1.8rem; }
            .back-nav { top: -2.5rem; left: 1rem; }
            .bg-light-gif-container { flex-direction: column; }
            .bg-light-gif-left, .bg-light-gif-right { width: 100%; height: 50%; }
        }
    </style>
</head>
<body>

    <div class="bg-light-gif-container">
        <div class="bg-light-gif-left"></div>
        <div class="bg-light-gif-right"></div>
    </div>

    <div class="auth-container">
        <a asp-controller="Home" asp-action="Index" class="back-nav">
            <i class="fa-solid fa-arrow-left"></i> Back to Marketplace
        </a>

        <div class="auth-card">
            <div class="auth-header">
                <h1>Welcome Back</h1>
                <p>Log in to your Lasamify account</p>
            </div>

            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div class="alert-error">
                    <ul>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            @foreach (var error in modelState.Errors)
                            {
                                <li>@error.ErrorMessage</li>
                            }
                        }
                    </ul>
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="Login">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label" for="email">Email Address</label>
                    <input asp-for="Email" type="email" class="form-input" id="email" placeholder="you@example.com" required />
                </div>

                <div class="form-group">
                    <label class="form-label" for="password">Password</label>
                    <input asp-for="Password" type="password" class="form-input" id="password" placeholder="••••••" required />
                </div>

                <div class="checkbox-group">
                    <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                    <label for="rememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn-primary">
                    <i class="fa-solid fa-arrow-right-to-bracket me-2"></i>Sign In
                </button>
            </form>

            <div class="divider">or</div>

            <div class="auth-footer">
                Don't have an account?
                <a asp-controller="Account" asp-action="Register" class="auth-link">Create one for free</a>
            </div>
        </div>
    </div>

</body>
</html>