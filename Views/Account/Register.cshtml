@model Lasamify.Models.RegisterViewModel
@{
    ViewData["Title"] = "Sign Up";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lasamify — Sign Up</title>
    <link rel="icon" type="image/jpeg" href="~/favicon/favicon.jpg" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --primary: #FFB703;
            --primary-hover: #FF9E00;
            --black: #0B0F19;
            --gray: #64748B;
            --white: #FFFFFF;
            --error: #DC2626;
            --glass-bg: rgba(255, 255, 255, 0.80);
            --glass-border: rgba(255, 255, 255, 0.5);
            --glass-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
        }

        body {
            font-family: 'DM Sans', sans-serif;
            color: var(--black);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        h1, h2, h3, .logo { font-family: 'Outfit', sans-serif; }

        .bg-light-gif-container {
            position: fixed;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: -1;
            display: flex;
        }

        .bg-light-gif-left {
            width: 50%; height: 100%;
            background: url('/images/light-bg3.gif') top left;
            background-size: 100% auto;
            background-repeat: repeat-y;
        }

        .bg-light-gif-right {
            width: 50%; height: 100%;
            background: url('/images/light-bg3.gif') top left;
            background-size: 100% auto;
            background-repeat: repeat-y;
            transform: scaleX(-1);
        }

        nav {
            display: flex;
            justify-content: space-between; align-items: center;
            padding: 1.2rem 4rem; position: sticky; top: 0;
            background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(0,0,0,0.05); z-index: 100;
        }

        .logo { font-size: 1.75rem; font-weight: 900; color: var(--black); letter-spacing: -0.5px; text-decoration: none; display: flex; align-items: center; gap: 8px; }
        .logo-dot { width: 12px; height: 12px; background: var(--primary); border-radius: 50%; display: inline-block; }
        
        .nav-links a { color: var(--gray); text-decoration: none; font-size: 0.95rem; font-weight: 700; transition: color 0.2s; }
        .nav-links a:hover { color: var(--black); }

        .auth-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 4rem 2rem;
            position: relative;
        }

        .auth-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-radius: 16px;
            padding: 3rem;
            box-shadow: var(--glass-shadow);
            border: 1px solid var(--glass-border);
            width: 100%;
            max-width: 480px;
            position: relative;
            z-index: 2;
        }

        .auth-header {
            margin-bottom: 2.5rem;
            text-align: center;
        }

        .auth-header h1 {
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--black);
            margin-bottom: 0.5rem;
        }

        .auth-header p {
            color: var(--gray);
            font-size: 0.95rem;
            font-weight: 600;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            font-weight: 700;
            color: var(--black);
            margin-bottom: 0.5rem;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-input,
        .form-select {
            width: 100%;
            padding: 1rem 1.25rem;
            border: 1px solid rgba(0, 0, 0, 0.1);
            border-radius: 8px;
            font-size: 1rem;
            font-family: 'DM Sans', sans-serif;
            transition: all 0.2s;
            background: rgba(255, 255, 255, 0.8);
            color: var(--black);
        }

        .form-input:focus,
        .form-select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(255, 183, 3, 0.2);
            background: var(--white);
        }

        .form-select {
            cursor: pointer;
        }

        .validation-error {
            color: var(--error);
            font-size: 0.8rem;
            margin-top: 0.35rem;
            display: block;
            font-weight: 600;
        }

        .btn-primary {
            width: 100%;
            padding: 1rem;
            background: var(--primary);
            color: var(--black);
            border: none;
            border-radius: 8px;
            font-weight: 800;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 14px rgba(255, 183, 3, 0.3);
            margin-top: 1rem;
        }

        .btn-primary:hover {
            background: var(--primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 183, 3, 0.4);
        }

        .divider {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 2rem 0;
            color: var(--gray);
            font-size: 0.85rem;
            font-weight: 700;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: rgba(0, 0, 0, 0.1);
        }

        .auth-footer {
            text-align: center;
            color: var(--gray);
            font-size: 0.95rem;
            font-weight: 600;
        }

        .auth-footer a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 800;
            transition: color 0.2s;
        }

        .auth-footer a:hover {
            color: var(--primary-hover);
            text-decoration: underline;
        }

        .alert-error {
            background: rgba(220, 38, 38, 0.1);
            border: 1px solid rgba(220, 38, 38, 0.2);
            color: var(--error);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            font-weight: 600;
        }

        .alert-error ul {
            margin: 0;
            padding-left: 1.25rem;
        }

        @@media (max-width: 640px) {
            nav { padding: 1rem 1.5rem; }
            .auth-card { padding: 2rem; }
            .auth-header h1 { font-size: 1.8rem; }
            .bg-light-gif-container { flex-direction: column; }
            .bg-light-gif-left, .bg-light-gif-right { width: 100%; height: 50%; }
        }
    </style>
</head>
<body>

<nav>
    <a class="logo" asp-controller="Home" asp-action="Landing">
        <span class="logo-dot"></span> Lasamify
    </a>
    <div class="nav-links">
        <a asp-controller="Home" asp-action="Landing">Back to Home</a>
    </div>
</nav>

<div class="bg-light-gif-container">
    <div class="bg-light-gif-left"></div>
    <div class="bg-light-gif-right"></div>
</div>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Join Lasamify</h1>
            <p>Create your account to start buying and selling</p>
        </div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert-error">
                <ul>
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <form method="post" asp-controller="Account" asp-action="Register">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label class="form-label" for="username">Username</label>
                <input asp-for="Username" class="form-input" id="username" placeholder="juandelacruz" required />
                <span asp-validation-for="Username" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="email">Email Address</label>
                <input asp-for="Email" type="email" class="form-input" id="email" placeholder="you@example.com" required />
                <span asp-validation-for="Email" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input asp-for="Password" type="password" class="form-input" id="password" placeholder="Min. 6 characters" required />
                <span asp-validation-for="Password" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="confirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="form-input" id="confirmPassword" placeholder="Re-enter password" required />
                <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
            </div>

            <div class="form-group">
                <label class="form-label" for="role">I am a...</label>
                <select asp-for="Role" class="form-select" id="role">
                    <option value="Buyer">Buyer</option>
                    <option value="Seller">Seller</option>
                </select>
            </div>

            <button type="submit" class="btn-primary">
                <i class="fa-solid fa-user-plus me-2"></i>Create Account
            </button>
        </form>

        <div class="divider">or</div>

        <div class="auth-footer">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Sign in here</a>
        </div>
    </div>
</div>

</body>
</html>