@model Lasamify.Models.User
@{
    ViewData["Title"] = "My Profile";
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm text-center p-4">
            @if (!string.IsNullOrEmpty(Model?.ProfilePicturePath))
            {
                <img src="@Model.ProfilePicturePath" class="rounded-circle mb-3 mx-auto"
                     style="width:120px;height:120px;object-fit:cover;border:3px solid #ffc107" alt="Profile" />
            }
            else
            {
                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto mb-3"
                     style="width:120px;height:120px">
                    <i class="fa-solid fa-user fa-3x text-white"></i>
                </div>
            }

            <h5 class="fw-bold">@Model?.Username</h5>
            <p class="text-muted small mb-1">@Model?.Email</p>
            <span class="badge @(Model?.Role == "Seller" ? "bg-warning text-dark" : "bg-info text-dark")">
                @Model?.Role
            </span>
            <p class="text-muted small mt-2">
                Member since @Model?.CreatedAt.ToString("MMMM yyyy")
            </p>

            <div class="mt-3">
                <form method="post" enctype="multipart/form-data"
                      asp-controller="Account" asp-action="UploadProfilePicture">
                    @Html.AntiForgeryToken()
                    <input type="file" name="profilePicture" class="form-control form-control-sm mb-2" accept="image/*" />
                    <button type="submit" class="btn btn-outline-warning btn-sm w-100">
                        <i class="fa-solid fa-camera me-1"></i>Update Photo
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
                <h6 class="mb-0"><i class="fa-solid fa-tags me-2"></i>My Listings (@Model?.Products.Count)</h6>
                <a asp-controller="Products" asp-action="Create" class="btn btn-warning btn-sm">
                    <i class="fa-solid fa-plus me-1"></i>Add Product
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model?.Products.Any() == true)
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Products)
                            {
                                <tr>
                                    <td>@p.Name</td>
                                    <td>₱@p.Price.ToString("N2")</td>
                                    <td>@p.Stock</td>
                                    <td>
                                        <span class="badge @(p.IsAvailable ? "bg-success" : "bg-secondary")">
                                            @(p.IsAvailable ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <form method="post" asp-controller="Products" asp-action="Delete" asp-route-id="@p.Id"
                                              onsubmit="return confirm('Remove this product?')">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-outline-danger btn-sm">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No products listed yet.</p>
                }
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h6 class="mb-0"><i class="fa-solid fa-receipt me-2"></i>My Purchases (@Model?.BuyerTransactions.Count)</h6>
            </div>
            <div class="card-body p-0">
                @if (Model?.BuyerTransactions.Any() == true)
                {
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Qty</th>
                                <th>Total</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.BuyerTransactions.OrderByDescending(x => x.TransactionDate))
                            {
                                <tr>
                                    <td>@t.Product?.Name</td>
                                    <td>@t.Quantity</td>
                                    <td>₱@t.TotalAmount.ToString("N2")</td>
                                    <td>
                                        <span class="badge @(t.Status == "Completed" ? "bg-success" : t.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark")">
                                            @t.Status
                                        </span>
                                    </td>
                                    <td class="small text-muted">@t.TransactionDate.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted p-3 mb-0">No purchases yet.</p>
                }
            </div>
        </div>
    </div>
</div>
